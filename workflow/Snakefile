configfile: "config/config.yaml"

import shlex


# Read dataset settings from config/config.yaml.
DATASETS = config["datasets"]

# Only antibiotics listed here will run.
ACTIVE_ANTIBIOTICS = config["active_antibiotics"]
NCBI_DATASETS = config.get("ncbi_datasets", {})
QUAST = config.get("quast", {})
GWAS = config.get("gwas", {})
GWAS_PHENOTYPE = GWAS.get("phenotype", {})
GWAS_INPUTS = GWAS.get("inputs", {})
GWAS_POPULATION_STRUCTURE = GWAS.get("population_structure", {})
MASH_MDS = GWAS_POPULATION_STRUCTURE.get("mash_mds", {})
PHYLOGENY_MDS = GWAS_POPULATION_STRUCTURE.get("phylogeny_mds", {})

IMPLEMENTED_GWAS_INPUTS = {"genes"}
KNOWN_GWAS_INPUTS = {"genes", "snps", "kmers"}
ALLOWED_GENE_POPULATION_METHODS = {"none", "mash_mds", "phylogeny_mds"}


def optional_quast_arg(flag, value):
    if value in [None, "", "null"]:
        return ""
    return f"{flag} {shlex.quote(str(value))}"


def quast_annotation_arg():
    reference = QUAST.get("reference")
    annotation = QUAST.get("annotation")

    if annotation not in [None, "", "null"] and reference in [None, "", "null"]:
        raise ValueError("quast.annotation requires quast.reference to be set.")

    return optional_quast_arg("-g", annotation)


def optional_config_arg(flag, value):
    if value in [None, "", "null"]:
        return ""
    return f"{flag} {shlex.quote(str(value))}"


def as_list(value):
    if value in [None, "", "null"]:
        return []
    if isinstance(value, str):
        return [value]
    return list(value)


def comma_join(values):
    values = as_list(values)
    return ", ".join(str(value) for value in values) if values else "none"


def input_config(input_name):
    return GWAS_INPUTS.get(input_name, {})


def population_methods(input_name):
    return as_list(
        input_config(input_name).get("population_structure", {}).get("methods", [])
    )


def mds_dimensions(input_name):
    return (
        input_config(input_name)
        .get("population_structure", {})
        .get("mds_dimensions", 8)
    )


def covariates_for_input(input_name):
    return as_list(
        input_config(input_name).get("population_structure", {}).get("covariates", [])
    )


def covariate_folder(input_name):
    covariates = covariates_for_input(input_name)
    if not covariates:
        return "no_covariates"
    return "covariates_" + "_".join(str(covariate) for covariate in covariates)


def phenotype_column_name(wildcards):
    return f"{DATASETS[wildcards.antibiotic]['antibiotic_name']}_log2"


def gene_fixed_effects_dir(antibiotic, method):
    return (
        f"results/{antibiotic}/gwas/fixed_effects/gene/"
        f"{method}/{covariate_folder('genes')}"
    )


def gene_fixed_effects_outputs_for_method(antibiotic, method):
    outdir = gene_fixed_effects_dir(antibiotic, method)
    outputs = [
        f"{outdir}/{antibiotic}_gene_{method}_pyseer.txt",
        f"{outdir}/{antibiotic}_gene_{method}_patterns.txt",
        f"{outdir}/{antibiotic}_gene_{method}_top_hits.tsv",
        f"{outdir}/{antibiotic}_gene_{method}_qq_plot.png",
        f"{outdir}/{antibiotic}_gene_{method}_significance_thresholds.txt",
        f"{outdir}/{antibiotic}_gene_{method}_notes_summary.tsv",
        f"{outdir}/{antibiotic}_gene_{method}_manhattan_plot.png",
    ]
    if method in ["mash_mds", "phylogeny_mds"]:
        outputs.append(f"{outdir}/{method}.pkl")
    return outputs


def validate_input_covariates(input_name):
    configured = set(as_list(GWAS.get("covariates", {}).get("columns", [])))
    requested = set(covariates_for_input(input_name))
    missing = sorted(requested - configured)
    if missing:
        raise ValueError(
            f"GWAS {input_name} covariate(s) not present in gwas.covariates.columns: "
            f"{comma_join(missing)}"
        )


def pyseer_covariate_args(input_name, antibiotic):
    validate_input_covariates(input_name)
    covariates = covariates_for_input(input_name)
    if not covariates:
        return ""

    metadata = f"results/{antibiotic}/gwas/phenotypes/{antibiotic}_metadata.tsv"
    all_columns = ["wgs_id"] + as_list(GWAS.get("covariates", {}).get("columns", []))
    use_covariates = []
    for covariate in covariates:
        index = all_columns.index(covariate) + 1
        suffix = "q" if covariate == "collection_year" else ""
        use_covariates.append(f"{index}{suffix}")

    return (
        f"--covariates {shlex.quote(metadata)} "
        f"--use-covariates {' '.join(use_covariates)}"
    )


def active_gwas_inputs():
    requested = as_list(GWAS.get("active_inputs", []))
    if "all" in requested:
        requested = ["genes", "snps", "kmers"]
    return requested


def validate_gwas_config():
    if config.get("skip_gwas_runs", True):
        return

    active = active_gwas_inputs()
    unknown = sorted(set(active) - KNOWN_GWAS_INPUTS)
    if unknown:
        raise ValueError(f"Unknown GWAS input(s): {comma_join(unknown)}")

    not_implemented = sorted(set(active) - IMPLEMENTED_GWAS_INPUTS)
    if not_implemented:
        raise ValueError(
            "These GWAS input(s) are config-ready but not implemented yet: "
            f"{comma_join(not_implemented)}"
        )

    if "genes" in active and config.get("skip_pangenome", False):
        raise ValueError(
            "gwas.active_inputs includes genes, but skip_pangenome is true. "
            "Gene GWAS input requires Panaroo pangenome outputs."
        )

    gene_methods = set(population_methods("genes"))
    invalid_gene_methods = sorted(gene_methods - ALLOWED_GENE_POPULATION_METHODS)
    if "genes" in active and invalid_gene_methods:
        raise ValueError(
            "Unsupported genes population structure method(s): "
            f"{comma_join(invalid_gene_methods)}. "
            f"Allowed now: {comma_join(sorted(ALLOWED_GENE_POPULATION_METHODS))}"
        )

    validate_input_covariates("genes")


validate_gwas_config()


def panaroo_qc_ref_db_path():
    return config.get("panaroo_qc", {}).get("ref_db")


def panaroo_qc_ref_db_rule_output():
    ref_db = panaroo_qc_ref_db_path()
    if ref_db in [None, "", "null"]:
        return "resources/panaroo_qc/.unused_ref_db"
    return ref_db


def panaroo_qc_ref_db_inputs(wildcards=None):
    if config.get("skip_panaroo_qc", False):
        return []

    ref_db = panaroo_qc_ref_db_path()
    if ref_db in [None, "", "null"]:
        return []

    return [ref_db]


def panaroo_qc_ref_db_arg():
    ref_db = panaroo_qc_ref_db_path()
    if ref_db in [None, "", "null"]:
        return ""

    return f"--ref_db {shlex.quote(str(ref_db))}"


def assembly_dependencies(wildcards):
    if config.get("skip_assembly_download", False):
        return []

    return [
        f"results/{wildcards.antibiotic}/downloads/{wildcards.antibiotic}_assembly_manifest.csv",
        f"results/{wildcards.antibiotic}/assemblies",
    ]


def prokka_dependency(wildcards):
    if config.get("skip_prokka", False):
        return []
    return [f"results/{wildcards.antibiotic}/annotation/prokka/.prokka_done"]


def prokka_outputs():
    if config.get("skip_prokka", False):
        return []

    return expand(
        "results/{antibiotic}/annotation/prokka/.prokka_done",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )


def pangenome_outputs():
    if config.get("skip_pangenome", False):
        return []

    outputs = []
    outputs += expand(
        "results/{antibiotic}/pangenome/panaroo/gene_presence_absence.csv",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    outputs += expand(
        "results/{antibiotic}/pangenome/panaroo/gene_presence_absence.Rtab",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    outputs += expand(
        "results/{antibiotic}/pangenome/panaroo/core_gene_alignment.aln",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    return outputs


def metadata_outputs():
    # If true, skip this metadata-cleaning step.
    if config.get("skip_metadata", False):
        return []

    outputs = []

    # Make one clean metadata CSV and one summary for each active antibiotic.
    outputs += expand(
        "results/{antibiotic}/metadata/{antibiotic}_clean_metadata.csv",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    outputs += expand(
        "results/{antibiotic}/metadata/{antibiotic}_metadata_summary.yaml",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    outputs += expand(
        "results/{antibiotic}/metadata/{antibiotic}_clean_metadata_with_assembly.csv",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    outputs += expand(
        "results/{antibiotic}/metadata/{antibiotic}_mic_log2_stats.csv",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    outputs += expand(
        "results/{antibiotic}/metadata/{antibiotic}_mic_log2_counts.csv",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    outputs += expand(
        "results/{antibiotic}/metadata/{antibiotic}_mic_log2_pie_chart.png",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )

    if not config.get("skip_assembly_metadata", False):
        outputs += expand(
            "results/{antibiotic}/metadata/{antibiotic}_assembly_metadata.csv",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )

    if not config.get("skip_sequence_metadata", False):
        outputs += expand(
            "results/{antibiotic}/metadata/{antibiotic}_sequencing_metadata.csv",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )
        outputs += expand(
            "results/{antibiotic}/metadata/{antibiotic}_combined_metadata.csv",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )

    return outputs


def assembly_download_outputs():
    if config.get("skip_assembly_download", False):
        return []

    outputs = []
    outputs += expand(
        "results/{antibiotic}/downloads/{antibiotic}_assembly_accessions.txt",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    outputs += expand(
        "results/{antibiotic}/downloads/{antibiotic}_assembly_manifest.csv",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    return outputs


def phenotype_data_outputs():
    if config.get("skip_phenotype_data", False):
        return []

    outputs = []
    outputs += expand(
        "results/{antibiotic}/gwas/phenotypes/{antibiotic}_phenotype.tsv",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    outputs += expand(
        "results/{antibiotic}/gwas/phenotypes/{antibiotic}_metadata.tsv",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )

    return outputs


def gwas_input_outputs():
    outputs = []
    outputs += expand(
        "results/{antibiotic}/gwas/phenotypes/{antibiotic}_phenotype.tsv",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    outputs += expand(
        "results/{antibiotic}/gwas/phenotypes/{antibiotic}_metadata.tsv",
        antibiotic=ACTIVE_ANTIBIOTICS,
    )
    if "genes" in active_gwas_inputs():
        outputs += expand(
            "results/{antibiotic}/pangenome/panaroo/gene_presence_absence.Rtab",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )
        outputs += expand(
            "results/{antibiotic}/pangenome/panaroo/core_gene_alignment.aln",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )

    return outputs


def gwas_population_structure_outputs():
    if config.get("skip_gwas_population_structure", False):
        return []

    outputs = []
    if "mash_mds" in population_methods("genes"):
        outputs += expand(
            "results/{antibiotic}/gwas/population_structure/mash_mds/mash_sketch.msh",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )
        outputs += expand(
            "results/{antibiotic}/gwas/population_structure/mash_mds/mash.tsv",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )
        outputs += expand(
            "results/{antibiotic}/gwas/population_structure/mash_mds/scree_plot.png",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )

    if "phylogeny_mds" in population_methods("genes"):
        outputs += expand(
            "results/{antibiotic}/gwas/population_structure/phylogeny_mds/core_gene_alignment.tree",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )
        outputs += expand(
            "results/{antibiotic}/gwas/population_structure/phylogeny_mds/phylogeny_dists.tsv",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )
        outputs += expand(
            "results/{antibiotic}/gwas/population_structure/phylogeny_mds/scree_plot.png",
            antibiotic=ACTIVE_ANTIBIOTICS,
        )

    return outputs


def gwas_fixed_effects_outputs(respect_skip=True):
    if respect_skip and config.get("skip_gwas_runs", True):
        return []

    outputs = []
    if "genes" in active_gwas_inputs():
        for antibiotic in ACTIVE_ANTIBIOTICS:
            for method in population_methods("genes"):
                outputs.extend(gene_fixed_effects_outputs_for_method(antibiotic, method))

    return outputs


