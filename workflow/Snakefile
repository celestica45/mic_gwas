        test -s {output.mds} || (echo "pyseer did not create {output.mds}" >&2; exit 1)
        """


rule summarize_gene_pyseer_top_hits:
    input:
        pyseer="results/{antibiotic}/gwas/fixed_effects/gene/{population_method}/{covariate_status}/{antibiotic}_gene_{population_method}_pyseer.txt",
    output:
        top_hits="results/{antibiotic}/gwas/fixed_effects/gene/{population_method}/{covariate_status}/{antibiotic}_gene_{population_method}_top_hits.tsv",
    message:
        "Sorting fixed-effects gene GWAS hits for {wildcards.antibiotic}: {output.top_hits}"
    shell:
        """
        mkdir -p $(dirname {output.top_hits})
        head -n 1 {input.pyseer} > {output.top_hits}
        tail -n +2 {input.pyseer} | sort -g -k4,4 >> {output.top_hits}
        """


rule plot_gene_pyseer_qq:
    input:
        pyseer="results/{antibiotic}/gwas/fixed_effects/gene/{population_method}/{covariate_status}/{antibiotic}_gene_{population_method}_pyseer.txt",
    output:
        plot="results/{antibiotic}/gwas/fixed_effects/gene/{population_method}/{covariate_status}/{antibiotic}_gene_{population_method}_qq_plot.png",
    conda:
        "envs/pyseer.yaml"
    message:
        "Creating fixed-effects gene GWAS QQ plot for {wildcards.antibiotic}: {output.plot}"
    shell:
        """
        python workflow/scripts/plot_pyseer_qq.py \
          --input {input.pyseer} \
          --output {output.plot} \
          --pvalue-column lrt-pvalue
        """


rule summarize_gene_gwas_postprocess:
    input:
        pyseer="results/{antibiotic}/gwas/fixed_effects/gene/{population_method}/{covariate_status}/{antibiotic}_gene_{population_method}_pyseer.txt",
        patterns="results/{antibiotic}/gwas/fixed_effects/gene/{population_method}/{covariate_status}/{antibiotic}_gene_{population_method}_patterns.txt",
    output:
        thresholds="results/{antibiotic}/gwas/fixed_effects/gene/{population_method}/{covariate_status}/{antibiotic}_gene_{population_method}_significance_thresholds.txt",
        notes="results/{antibiotic}/gwas/fixed_effects/gene/{population_method}/{covariate_status}/{antibiotic}_gene_{population_method}_notes_summary.tsv",
        manhattan="results/{antibiotic}/gwas/fixed_effects/gene/{population_method}/{covariate_status}/{antibiotic}_gene_{population_method}_manhattan_plot.png",
    conda:
        "envs/pyseer.yaml"
    params:
        label_top_n=GWAS.get("plots", {})
        .get("gene_manhattan", {})
        .get("label_top_n", 10),
        label_significant=str(
            GWAS.get("plots", {})
            .get("gene_manhattan", {})
            .get("label_significant", True)
        ).lower(),
        label_max=GWAS.get("plots", {})
        .get("gene_manhattan", {})
        .get("label_max", 25),
    message:
        "Summarizing fixed-effects gene GWAS post-processing for {wildcards.antibiotic}: thresholds, notes, and Manhattan-like plot"
    shell:
        """
        python workflow/scripts/summarize_pyseer_gene_gwas.py \
          --pyseer {input.pyseer} \
          --patterns {input.patterns} \
          --thresholds {output.thresholds} \
          --notes {output.notes} \
          --manhattan {output.manhattan} \
          --label-top-n {params.label_top_n} \
          --label-significant {params.label_significant} \
          --label-max {params.label_max}
        """


