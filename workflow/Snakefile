rule all:
    input:
        metadata_outputs(),
        assembly_download_outputs(),
        quast_outputs(),
        prokka_outputs(),
        panaroo_qc_outputs(),
        pangenome_outputs(),
        phenotype_data_outputs(),
        gwas_population_structure_outputs(),
        gwas_fixed_effects_outputs(),


rule quast_stage:
    input:
        quast_outputs(),


rule prokka_stage:
    input:
        prokka_outputs(),


rule assembly_download_stage:
    input:
        assembly_download_outputs(),


rule phenotype_data_stage:
    input:
        phenotype_data_outputs(),
    params:
        phenotype_column=GWAS_PHENOTYPE.get("log2_column", "mic_log2"),
        sample_column=GWAS_PHENOTYPE.get("sample_column", "assembly_ID"),
        covariates=comma_join(GWAS.get("covariates", {}).get("columns", [])),
    message:
        "Phenotype data stage: phenotype={params.phenotype_column}; sample={params.sample_column}; covariates={params.covariates}"


rule gwas_inputs_stage:
    input:
        gwas_input_outputs(),
    params:
        active_inputs=comma_join(active_gwas_inputs()),
        phenotype_column=GWAS_PHENOTYPE.get("log2_column", "mic_log2"),
        sample_column=GWAS_PHENOTYPE.get("sample_column", "assembly_ID"),
        genes_methods=comma_join(population_methods("genes")),
        snps_methods=comma_join(population_methods("snps")),
        kmers_methods=comma_join(population_methods("kmers")),
    message:
        "GWAS input stage: active_inputs={params.active_inputs}; phenotype={params.phenotype_column}; sample={params.sample_column}; genes_methods={params.genes_methods}; snps_methods={params.snps_methods}; kmers_methods={params.kmers_methods}"


rule gwas_population_structure_stage:
    input:
        gwas_population_structure_outputs(),


rule gwas_gene_fixed_effects_stage:
    input:
        gwas_fixed_effects_outputs(respect_skip=False),


rule panaroo_qc_stage:
    input:
        panaroo_qc_outputs(),


rule clean_metadata:
    input:
        # wildcards.antibiotic comes from the output path.
        raw_metadata=lambda wildcards: DATASETS[wildcards.antibiotic]["raw_metadata"],
    output:
        clean_metadata="results/{antibiotic}/metadata/{antibiotic}_clean_metadata.csv",
        clean_metadata_with_assembly="results/{antibiotic}/metadata/{antibiotic}_clean_metadata_with_assembly.csv",
        summary="results/{antibiotic}/metadata/{antibiotic}_metadata_summary.yaml",
        mic_log2_stats="results/{antibiotic}/metadata/{antibiotic}_mic_log2_stats.csv",
        mic_log2_counts="results/{antibiotic}/metadata/{antibiotic}_mic_log2_counts.csv",
        mic_log2_pie_chart="results/{antibiotic}/metadata/{antibiotic}_mic_log2_pie_chart.png",
    params:
        antibiotic_name=lambda wildcards: DATASETS[wildcards.antibiotic][
            "antibiotic_name"
        ],
        organism=lambda wildcards: DATASETS[wildcards.antibiotic]["organism"],
    shell:
        """
        python workflow/scripts/clean_metadata.py \
          --input {input.raw_metadata} \
          --output {output.clean_metadata} \
          --output-with-assembly {output.clean_metadata_with_assembly} \
          --summary {output.summary} \
          --mic-log2-stats {output.mic_log2_stats} \
          --mic-log2-counts {output.mic_log2_counts} \
          --mic-log2-pie-chart {output.mic_log2_pie_chart} \
          --antibiotic-name '{params.antibiotic_name}' \
          --organism '{params.organism}'
        """


rule prepare_pyseer_phenotype:
    input:
        metadata="results/{antibiotic}/metadata/{antibiotic}_clean_metadata_with_assembly.csv",
    output:
        phenotype_tsv="results/{antibiotic}/gwas/phenotypes/{antibiotic}_phenotype.tsv",
        metadata_tsv="results/{antibiotic}/gwas/phenotypes/{antibiotic}_metadata.tsv",
    params:
        sample_column=GWAS_PHENOTYPE.get("sample_column", "assembly_ID"),
        log2_column=GWAS_PHENOTYPE.get("log2_column", "mic_log2"),
        log2_column_name=lambda wc: f"{DATASETS[wc.antibiotic]['antibiotic_name']}_log2",
        covariates=lambda wc: " ".join(GWAS.get("covariates", {}).get("columns", [])),
    message:
        "Preparing phenotype data for {wildcards.antibiotic}: sample={params.sample_column}, log2={params.log2_column}, covariates={params.covariates}"
    shell:
        """
        echo "Phenotype data input: {wildcards.antibiotic}"
        echo "Sample column: {params.sample_column}"
        echo "Log2 phenotype column: {params.log2_column}"
        echo "Covariates: {params.covariates}"
        python workflow/scripts/prepare_pyseer_phenotype.py \
          --metadata {input.metadata} \
          --phenotype-tsv {output.phenotype_tsv} \
          --metadata-tsv {output.metadata_tsv} \
          --sample-column {params.sample_column} \
          --log2-column {params.log2_column} \
          --log2-column-name {params.log2_column_name} \
          --covariates {params.covariates}
        """


rule mash_sketch_assemblies:
    input:
        assembly_dependencies,
    output:
        sketch="results/{antibiotic}/gwas/population_structure/mash_mds/mash_sketch.msh",
    params:
        assemblies_dir="results/{antibiotic}/assemblies",
        outprefix="results/{antibiotic}/gwas/population_structure/mash_mds/mash_sketch",
        sketch_size=MASH_MDS.get("sketch_size", 10000),
        extension=config.get("prokka", {}).get("extension", "fa"),
        mds_dimensions=lambda wc: input_config("genes")
        .get("population_structure", {})
        .get("mds_dimensions", 8),
    conda:
        "envs/pyseer.yaml"
    message:
        "GWAS population structure for {wildcards.antibiotic}: method=mash_mds, assemblies={params.assemblies_dir}, mds_dimensions={params.mds_dimensions}"
    shell:
        """
        echo "GWAS population structure: {wildcards.antibiotic}"
        echo "Method: mash_mds"
        echo "Assembly directory: {params.assemblies_dir}"
        echo "MDS dimensions: {params.mds_dimensions}"
        mkdir -p $(dirname {output.sketch})
        mash sketch \
          -s {params.sketch_size} \
          -o {params.outprefix} \
          {params.assemblies_dir}/*.{params.extension}
        """


rule calculate_mash_distances:
    input:
        sketch="results/{antibiotic}/gwas/population_structure/mash_mds/mash_sketch.msh",
    output:
        raw_distances="results/{antibiotic}/gwas/population_structure/mash_mds/mash_raw.tsv",
    conda:
        "envs/pyseer.yaml"
    message:
        "Calculating raw Mash distance matrix for {wildcards.antibiotic}: {output.raw_distances}"
    shell:
        """
        mash dist {input.sketch} {input.sketch} | square_mash > {output.raw_distances}
        """


rule normalize_mash_distance_labels:
    input:
        raw_distances="results/{antibiotic}/gwas/population_structure/mash_mds/mash_raw.tsv",
        manifest="results/{antibiotic}/downloads/{antibiotic}_assembly_manifest.csv",
    output:
        distances="results/{antibiotic}/gwas/population_structure/mash_mds/mash.tsv",
    message:
        "Normalizing Mash labels for {wildcards.antibiotic}: {output.distances}"
    shell:
        """
        python workflow/scripts/normalize_mash_distances.py \
          --manifest {input.manifest} \
          --input {input.raw_distances} \
          --output {output.distances}
        """


rule plot_mash_mds_scree:
    input:
        distances="results/{antibiotic}/gwas/population_structure/mash_mds/mash.tsv",
    output:
        plot="results/{antibiotic}/gwas/population_structure/mash_mds/scree_plot.png",
    params:
        max_dimensions=MASH_MDS.get("max_scree_dimensions", 30),
    conda:
        "envs/pyseer.yaml"
    message:
        "Creating Mash MDS scree plot for {wildcards.antibiotic}: {output.plot}"
    shell:
        """
        scree_plot_pyseer \
          --max-dimensions {params.max_dimensions} \
          --output {output.plot} \
          {input.distances}
        """


rule build_core_gene_iqtree:
    input:
        alignment="results/{antibiotic}/pangenome/panaroo/core_gene_alignment.aln",
    output:
        tree="results/{antibiotic}/gwas/population_structure/phylogeny_mds/core_gene_alignment.tree",
    threads:
        PHYLOGENY_MDS.get("threads", 4)
    params:
        prefix="results/{antibiotic}/gwas/population_structure/phylogeny_mds/core_gene_alignment",
        model=PHYLOGENY_MDS.get("model", "GTR"),
    conda:
        "envs/pyseer.yaml"
    message:
        "Building core-gene IQ-TREE phylogeny for {wildcards.antibiotic}: model={params.model}, output={output.tree}"
    shell:
        """
        mkdir -p $(dirname {output.tree})
        iqtree2 \
          -s {input.alignment} \
          -m {params.model} \
          -nt {threads} \
          -pre {params.prefix}
        cp {params.prefix}.treefile {output.tree}
        test -s {output.tree} || (echo "IQ-TREE did not create {output.tree}" >&2; exit 1)
        """


rule calculate_phylogeny_distances:
    input:
        tree="results/{antibiotic}/gwas/population_structure/phylogeny_mds/core_gene_alignment.tree",
    output:
        distances="results/{antibiotic}/gwas/population_structure/phylogeny_mds/phylogeny_dists.tsv",
    conda:
        "envs/pyseer.yaml"
    message:
        "Calculating phylogeny distance matrix for {wildcards.antibiotic}: {output.distances}"
    shell:
        """
        python workflow/scripts/phylogeny_distance.py \
          {input.tree} \
          > {output.distances}
        """


rule plot_phylogeny_mds_scree:
    input:
        distances="results/{antibiotic}/gwas/population_structure/phylogeny_mds/phylogeny_dists.tsv",
    output:
        plot="results/{antibiotic}/gwas/population_structure/phylogeny_mds/scree_plot.png",
    params:
        max_dimensions=PHYLOGENY_MDS.get(
            "max_scree_dimensions", MASH_MDS.get("max_scree_dimensions", 30)
        ),
    conda:
        "envs/pyseer.yaml"
    message:
        "Creating phylogeny MDS scree plot for {wildcards.antibiotic}: {output.plot}"
    shell:
        """
        scree_plot_pyseer \
          --max-dimensions {params.max_dimensions} \
          --output {output.plot} \
          {input.distances}
        """


rule run_pyseer_gene_fixed_effects_none:
    input:
        phenotype="results/{antibiotic}/gwas/phenotypes/{antibiotic}_phenotype.tsv",
        metadata="results/{antibiotic}/gwas/phenotypes/{antibiotic}_metadata.tsv",
        rtab="results/{antibiotic}/pangenome/panaroo/gene_presence_absence.Rtab",
    output:
        pyseer="results/{antibiotic}/gwas/fixed_effects/gene/none/{covariate_status}/{antibiotic}_gene_none_pyseer.txt",
        patterns="results/{antibiotic}/gwas/fixed_effects/gene/none/{covariate_status}/{antibiotic}_gene_none_patterns.txt",
    params:
        outdir="results/{antibiotic}/gwas/fixed_effects/gene/none/{covariate_status}",
        phenotype_column=phenotype_column_name,
        covariates=lambda wc: " ".join(covariates_for_input("genes")),
        covariate_args=lambda wc: pyseer_covariate_args("genes", wc.antibiotic),
        covariate_folder=lambda wc: covariate_folder("genes"),
    conda:
        "envs/pyseer.yaml"
    message:
        "Running fixed-effects gene GWAS for {wildcards.antibiotic}: population=none, covariates={params.covariate_folder}"
    shell:
        """
        mkdir -p {params.outdir}
        python workflow/scripts/validate_pyseer_gene_inputs.py \
          --phenotype {input.phenotype} \
          --rtab {input.rtab} \
          --metadata {input.metadata} \
          --covariates {params.covariates}
        pyseer \
          --continuous \
          --phenotypes {input.phenotype} \
          --phenotype-column {params.phenotype_column} \
          --pres {input.rtab} \
          --no-distances \
          --output-patterns {output.patterns} \
          {params.covariate_args} \
          > {output.pyseer}
        test -s {output.pyseer} || (echo "pyseer did not create {output.pyseer}" >&2; exit 1)
        test -s {output.patterns} || (echo "pyseer did not create {output.patterns}" >&2; exit 1)
        """


rule run_pyseer_gene_fixed_effects_mash_mds:
    input:
        phenotype="results/{antibiotic}/gwas/phenotypes/{antibiotic}_phenotype.tsv",
        metadata="results/{antibiotic}/gwas/phenotypes/{antibiotic}_metadata.tsv",
        rtab="results/{antibiotic}/pangenome/panaroo/gene_presence_absence.Rtab",
        distances="results/{antibiotic}/gwas/population_structure/mash_mds/mash.tsv",
    output:
        pyseer="results/{antibiotic}/gwas/fixed_effects/gene/mash_mds/{covariate_status}/{antibiotic}_gene_mash_mds_pyseer.txt",
        patterns="results/{antibiotic}/gwas/fixed_effects/gene/mash_mds/{covariate_status}/{antibiotic}_gene_mash_mds_patterns.txt",
        mds="results/{antibiotic}/gwas/fixed_effects/gene/mash_mds/{covariate_status}/mash_mds.pkl",
    params:
        outdir="results/{antibiotic}/gwas/fixed_effects/gene/mash_mds/{covariate_status}",
        phenotype_column=phenotype_column_name,
        mds_dimensions=lambda wc: mds_dimensions("genes"),
        covariates=lambda wc: " ".join(covariates_for_input("genes")),
        covariate_args=lambda wc: pyseer_covariate_args("genes", wc.antibiotic),
        covariate_folder=lambda wc: covariate_folder("genes"),
    conda:
        "envs/pyseer.yaml"
    message:
        "Running fixed-effects gene GWAS for {wildcards.antibiotic}: population=mash_mds, covariates={params.covariate_folder}, mds_dimensions={params.mds_dimensions}"
    shell:
        """
        mkdir -p {params.outdir}
        python workflow/scripts/validate_pyseer_gene_inputs.py \
          --phenotype {input.phenotype} \
          --rtab {input.rtab} \
          --distances {input.distances} \
          --metadata {input.metadata} \
          --covariates {params.covariates}
        pyseer \
          --continuous \
          --phenotypes {input.phenotype} \
          --phenotype-column {params.phenotype_column} \
          --pres {input.rtab} \
          --distances {input.distances} \
          --save-m {params.outdir}/mash_mds \
          --max-dimensions {params.mds_dimensions} \
          --output-patterns {output.patterns} \
          {params.covariate_args} \
          > {output.pyseer}
        test -s {output.pyseer} || (echo "pyseer did not create {output.pyseer}" >&2; exit 1)
        test -s {output.patterns} || (echo "pyseer did not create {output.patterns}" >&2; exit 1)
        test -s {output.mds} || (echo "pyseer did not create {output.mds}" >&2; exit 1)
        """


