rule download_ncbi_assemblies:
    input:
        accessions="results/{antibiotic}/downloads/{antibiotic}_assembly_accessions.txt",
    output:
        zips=temp(directory("results/{antibiotic}/downloads/ncbi_assemblies_zips")),
    params:
        batch_size=10,
        datasets_include=NCBI_DATASETS.get("include", "genome"),
    retries:
        3
    conda:
        "envs/ncbi_datasets.yaml"
    script:
        "scripts/download_ncbi_assemblies.py"


rule unpack_ncbi_assemblies:
    input:
        zips="results/{antibiotic}/downloads/ncbi_assemblies_zips",
        accessions="results/{antibiotic}/downloads/{antibiotic}_assembly_accessions.txt",
    output:
        assemblies_dir=directory("results/{antibiotic}/assemblies"),
        manifest="results/{antibiotic}/downloads/{antibiotic}_assembly_manifest.csv",
    script:
        "scripts/collect_ncbi_assemblies.py"


rule run_quast:
    input:
        assembly_dependencies,
    output:
        report_tsv="results/{antibiotic}/qc/quast/report.tsv",
        report_txt="results/{antibiotic}/qc/quast/report.txt",
        transposed_report_tsv="results/{antibiotic}/qc/quast/transposed_report.tsv",
    threads:
        int(QUAST.get("threads", 4))
    params:
        outdir="results/{antibiotic}/qc/quast",
        assemblies_dir="results/{antibiotic}/assemblies",
        min_contig_length=QUAST.get("min_contig_length", 500),
        extension=QUAST.get("extension", "fa"),
        reference_arg=optional_quast_arg("-r", QUAST.get("reference")),
        annotation_arg=quast_annotation_arg(),
    conda:
        "envs/quast.yaml"
    shell:
        """
        quast.py \
          --threads {threads} \
          --min-contig {params.min_contig_length} \
          {params.reference_arg} \
          {params.annotation_arg} \
          -o {params.outdir} \
          {params.assemblies_dir}/*.{params.extension}
        """


rule download_panaroo_qc_ref_db:
    output:
        ref_db=panaroo_qc_ref_db_rule_output(),
    params:
        url=config.get("panaroo_qc", {}).get("ref_db_url"),
        download=config.get("panaroo_qc", {}).get("download_ref_db", False),
    conda:
        "envs/panaroo.yaml"
    message:
        "Downloading Panaroo QC Mash reference DB: {params.url}"
    shell:
        """
        if [ "{params.download}" != "True" ] && [ "{params.download}" != "true" ]; then
          echo "panaroo_qc.ref_db is configured but panaroo_qc.download_ref_db is false." >&2
          echo "Either provide the file yourself or set download_ref_db: true." >&2
          exit 1
        fi
        if [ -z "{params.url}" ] || [ "{params.url}" = "None" ] || [ "{params.url}" = "null" ]; then
          echo "panaroo_qc.download_ref_db is true but panaroo_qc.ref_db_url is missing." >&2
          exit 1
        fi
        mkdir -p $(dirname {output.ref_db})
        wget -O {output.ref_db} {params.url}
        """


rule annotate_prokka:
    input:
        assembly_dependencies,
    output:
        done="results/{antibiotic}/annotation/prokka/.prokka_done",
    threads:
        int(config.get("prokka", {}).get("threads", 4))
    params:
        outdir="results/{antibiotic}/annotation/prokka",
        assemblies_dir="results/{antibiotic}/assemblies",
        extension=config.get("prokka", {}).get("extension", "fa"),
    conda:
        "envs/prokka.yaml"
    message:
        "Running Prokka for {wildcards.antibiotic}: assemblies={params.assemblies_dir}, outdir={params.outdir}"
    shell:
        """
        echo "Prokka annotation: {wildcards.antibiotic}"
        echo "Assembly directory: {params.assemblies_dir}"
        echo "Prokka output directory: {params.outdir}"
        mkdir -p {params.outdir}
        for fasta in {params.assemblies_dir}/*.{params.extension}; do
          test -e "$fasta" || (echo "No assembly FASTA files found in {params.assemblies_dir}" >&2; exit 1)
          sample=$(basename "$fasta" .{params.extension})
          prokka \
            --outdir {params.outdir}/"$sample" \
            --prefix "$sample" \
            --force \
            --cpus {threads} \
            "$fasta"
        done
        touch {output.done}
        """


rule run_panaroo_qc:
    input:
        prokka_done=prokka_dependency,
        ref_db=panaroo_qc_ref_db_inputs,
    output:
        done="results/{antibiotic}/qc/panaroo_qc/.qc_done",
    threads:
        int(config.get("panaroo_qc", {}).get("threads", 4))
    params:
        prokka_dir="results/{antibiotic}/annotation/prokka",
        outdir="results/{antibiotic}/qc/panaroo_qc",
        graph_type=config.get("panaroo_qc", {}).get("graph_type", "all"),
        ref_db_arg=panaroo_qc_ref_db_arg(),
    conda:
        "envs/panaroo.yaml"
    message:
        "Running Panaroo QC for {wildcards.antibiotic}: prokka_gffs={params.prokka_dir}, outdir={params.outdir}"
    shell:
        """
        echo "Panaroo QC: {wildcards.antibiotic}"
        echo "Prokka GFF directory: {params.prokka_dir}"
        echo "Panaroo QC output directory: {params.outdir}"
        echo "Panaroo QC graph type: {params.graph_type}"
        echo "Panaroo QC reference DB: {params.ref_db_arg}"
        mkdir -p {params.outdir}
        panaroo-qc \
          -t {threads} \
          --graph_type {params.graph_type} \
          -i {params.prokka_dir}/*/*.gff \
          {params.ref_db_arg} \
          -o {params.outdir}
        touch {output.done}
        """


rule run_panaroo:
    input:
        prokka_done=prokka_dependency,
        panaroo_qc_done=panaroo_qc_dependency,
    output:
        matrix="results/{antibiotic}/pangenome/panaroo/gene_presence_absence.csv",
        rtab="results/{antibiotic}/pangenome/panaroo/gene_presence_absence.Rtab",
        core_alignment="results/{antibiotic}/pangenome/panaroo/core_gene_alignment.aln",
        done="results/{antibiotic}/pangenome/panaroo/.panaroo_done",
    threads:
        int(config.get("panaroo", {}).get("threads", 4))
    params:
        prokka_dir="results/{antibiotic}/annotation/prokka",
        outdir="results/{antibiotic}/pangenome/panaroo",
        clean_mode=config.get("panaroo", {}).get("clean_mode", "strict"),
    conda:
        "envs/panaroo.yaml"
    message:
        "Running Panaroo for {wildcards.antibiotic}: prokka_gffs={params.prokka_dir}, outdir={params.outdir}"
    shell:
        """
        echo "Panaroo pangenome: {wildcards.antibiotic}"
        echo "Prokka GFF directory: {params.prokka_dir}"
        echo "Panaroo output directory: {params.outdir}"
        mkdir -p {params.outdir}
        panaroo \
          -i {params.prokka_dir}/*/*.gff \
          -o {params.outdir} \
          --clean-mode {params.clean_mode} \
          -a core \
          -t {threads}

        test -s {output.matrix} || (echo "Panaroo did not create {output.matrix}" >&2; exit 1)
        test -s {output.rtab} || (echo "Panaroo did not create {output.rtab}" >&2; exit 1)
        test -s {output.core_alignment} || (echo "Panaroo did not create {output.core_alignment}" >&2; exit 1)
        touch {output.done}
        """


